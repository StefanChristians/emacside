# -*- mode: snippet -*-
# name: gtest
# group: module
# --
include_guard(GLOBAL)

# GoogleTest — Google testing framework. Must be compiled with the same flags
# as the source code, so the system-installed binary version cannot be used.

# --- 1. Sibling dependencies ---

include(fetchcontent_persist)

# --- 2. Upstream build options ---

# do not install GoogleTest in the distribution target
set(INSTALL_GTEST OFF CACHE BOOL "" FORCE)

# To avoid harmless but irritating warnings about policy CMP0069, run this
# BEFORE INTERPROCEDURAL_OPTIMIZATION is turned on.
set(gtest_force_shared_crt ON CACHE BOOL "" FORCE)

# --- 3. Declare ---

FetchContent_Declare_Persist(
  googletest
  GIT_REPOSITORY "https://github.com/google/googletest.git"
  GIT_TAG "latest"
  GIT_PROGRESS ON
  GIT_SHALLOW ON
)

# --- 4. Make available ---

FetchContent_MakeAvailable(googletest)

# --- 5. Post-adapt ---

# activate CMake GoogleTest module (provides gtest_discover_tests())
include(GoogleTest)