# -*- mode: snippet -*-
# name: boost
# group: module
# --
include_guard(GLOBAL)

# Boost — collection of high-quality C++ libraries.

# --- 1. Sibling dependencies ---

include(fetchcontent_persist)

# --- 2. Upstream build options ---

# Boost.Iostreams probes the system for zstd and, if found, imports it as
# zstd::libzstd_shared - we don't need it
set(BOOST_IOSTREAMS_ENABLE_ZSTD OFF CACHE BOOL "" FORCE)

# --- 3. Declare ---

FetchContent_Declare_Persist(
  Boost
  GIT_REPOSITORY "https://github.com/boostorg/boost.git"
  GIT_TAG "latest"
  GIT_PROGRESS ON
  GIT_SHALLOW ON
  OVERRIDE_FIND_PACKAGE TRUE
  EXCLUDE_FROM_ALL
)

# --- 4. Make available ---

FetchContent_MakeAvailable(Boost)

# --- 5. Post-adapt ---

register_3rdparty(Boost
    DISPLAY      "Boost"
    URL          "https://www.boost.org/"
    LICENSE_NAME "Boost Software License 1.0"
    LICENSE_URL  "https://www.boost.org/users/license.html"
    LICENSE_FILE "LICENSE_1_0.txt"
)

