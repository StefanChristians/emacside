# -*- mode: snippet -*-
# name: coverage
# group: module
# --
include_guard(GLOBAL)

# Measure code covered by unit tests

# default location for generated coverage reports
set(CMAKE_COVERAGE_OUTPUT_DIR "output/reports/coverage" CACHE STRING "Output directory in build tree for generated code coverage reports.")

# required binaries
find_program(LLVMCOV_EXECUTABLE llvm-cov)
find_program(LLVMPROFDATA_EXECUTABLE llvm-profdata)
find_program(GCOV_EXECUTABLE gcov)
find_program(GCOVR_EXECUTABLE gcovr)
mark_as_advanced(LLVMCOV_EXECUTABLE LLVMPROFDATA_EXECUTABLE GCOV_EXECUTABLE GCOVR_EXECUTABLE)

set(COVERAGE_AVAILABLE True)

# check for required build configuration type
if(\$\{COVERAGE_AVAILABLE\})
  get_property(GENERATOR_IS_MULTI_CONFIG GLOBAL PROPERTY GENERATOR_IS_MULTI_CONFIG)
  if((NOT CMAKE_BUILD_TYPE STREQUAL "Debug") AND (NOT GENERATOR_IS_MULTI_CONFIG))
    message(STATUS "non-debug build configuration - code coverage disabled")
    set(COVERAGE_AVAILABLE False)
  endif()
endif()

# check for compatible compiler
if(\$\{COVERAGE_AVAILABLE\})
  if("\$\{CMAKE_C_COMPILER_ID\}" MATCHES "Clang" OR "\$\{CMAKE_CXX_COMPILER_ID\}" MATCHES "Clang")

    # using clang / clang++

    # check for llvm-cov executable
    if (LLVMCOV_EXECUTABLE)
      execute_process(
        COMMAND \$\{LLVMCOV_EXECUTABLE\} --version
        OUTPUT_VARIABLE LLVMCOV_VERSION
      )
      string(REGEX REPLACE ".*version ([^ ]+)\\n.*" "\\\\1" LLVMCOV_VERSION "\$\{LLVMCOV_VERSION\}")
      message(STATUS "Found llvm-cov: \$\{LLVMCOV_EXECUTABLE\} (found version \\"\$\{LLVMCOV_VERSION\}\\")")
    else()
      message(STATUS "llvm-cov not found - code coverage disabled")
      set(COVERAGE_AVAILABLE False)
    endif()

    # check for llvm-profdata executable
    if (LLVMPROFDATA_EXECUTABLE)
      message(STATUS "Found llvm-profdata: \$\{LLVMPROFDATA_EXECUTABLE\}")
    else()
      message(STATUS "llvm-profdata not found - code coverage disabled")
      set(COVERAGE_AVAILABLE False)
    endif()

  elseif("\$\{CMAKE_C_COMPILER_ID\}" MATCHES "GNU" OR "\$\{CMAKE_CXX_COMPILER_ID\}" MATCHES "GNU")

    # using gcc / g++

    # check for gcov executable
    if (GCOV_EXECUTABLE)
      execute_process(
        COMMAND \$\{GCOV_EXECUTABLE\} --version
        OUTPUT_VARIABLE GCOV_VERSION
      )
      string(REGEX REPLACE "^gcov[ \\\\(\\\\)A-Za-z]+ ([1-9\\\\.]+) .*" "\\\\1" GCOV_VERSION "\$\{GCOV_VERSION\}")
      message(STATUS "Found gcov: \$\{GCOV_EXECUTABLE\} (found version \\"\$\{GCOV_VERSION\}\\")")
    else()
      message(STATUS "gcov not found - code coverage disabled")
      set(COVERAGE_AVAILABLE False)
    endif()

    # check for GCovr executable
    if (GCOVR_EXECUTABLE)
      execute_process(
        COMMAND \$\{GCOVR_EXECUTABLE\} --version
        OUTPUT_VARIABLE GCOVR_VERSION
      )
      string(REGEX REPLACE "^gcovr ([^ \\t\\r\\n]+).*" "\\\\1" GCOVR_VERSION "\$\{GCOVR_VERSION\}")
      message(STATUS "Found GCovr: \$\{GCOVR_EXECUTABLE\} (found version \\"\$\{GCOVR_VERSION\}\\")")
    else()
      message(STATUS "GCovr not found - code coverage disabled")
      set(COVERAGE_AVAILABLE False)
    endif()

  else()
    message(STATUS "incompatible compiler - code coverage disabled")
    set(COVERAGE_AVAILABLE False)
  endif()
endif()


# configure code coverage
if(\$\{COVERAGE_AVAILABLE\})
  message(STATUS "code coverage measurements enabled")

  set(reportdir "\$\{PROJECT_BINARY_DIR\}/\$\{CMAKE_COVERAGE_OUTPUT_DIR\}")
  file(MAKE_DIRECTORY "\$\{reportdir\}")

  if("\$\{CMAKE_C_COMPILER_ID\}" MATCHES "GNU" OR "\$\{CMAKE_CXX_COMPILER_ID\}" MATCHES "GNU")

    # The gcov coverage target aggregates per-test run targets added by
    # report_coverage(); the gcovr invocation is wired in by finalize_coverage()
    # once all search dirs are known.
    add_custom_target(coverage
      COMMENT "Generating code coverage reports"
    )

  elseif("\$\{CMAKE_C_COMPILER_ID\}" MATCHES "Clang" OR "\$\{CMAKE_CXX_COMPILER_ID\}" MATCHES "Clang")

    set(datadir "\$\{reportdir\}/profiles")
    file(MAKE_DIRECTORY "\$\{datadir\}")
    # Response files are written per-config by finalize_coverage(); use \$<CONFIG>
    # in these paths so each config gets its own file and its own invocation.
    set(objects_cache "\$\{datadir\}/objects-\$<CONFIG>.txt")
    set(profiles_cache "\$\{reportdir\}/profiles-\$<CONFIG>.txt")
    set(merged_profiles "\$\{datadir\}/merged.profdata")

    # target to merge individual raw profiles — reads @profiles_cache written by
    # finalize_coverage() at generate time, so no glob over the filesystem needed
    add_custom_target(
      llvm-cov-merge
      COMMAND \$\{LLVMPROFDATA_EXECUTABLE\} merge --sparse "--input-files=\$\{profiles_cache\}" -o "\$\{merged_profiles\}"
      BYPRODUCTS "\$\{merged_profiles\}"
      COMMENT "Merging code coverage metrics"
      WORKING_DIRECTORY "\$\{CMAKE_BINARY_DIR\}"
      VERBATIM
    )

    # target to generate reports — uses @objects_cache response file so the
    # command is identical on every platform (no shell glob or powershell needed)
    add_custom_target(
      coverage
      # json export for machine consumption — \`llvm-cov export\` writes to stdout
      # and has no -o, so a helper captures its output via execute_process
      COMMAND \$\{CMAKE_COMMAND\}
        "-DLLVMCOV=\$\{LLVMCOV_EXECUTABLE\}"
        "-DOBJECTS=@\$\{objects_cache\}"
        "-DPROFILE=\$\{merged_profiles\}"
        "-DIGNORE_INTERFACE=.*_interface\\\\..*"
        "-DIGNORE_WRAPPER=.*_thin_wrapper\\\\..*"
        "-DOUTPUT=\$\{reportdir\}/coverage.json"
        -P "\$\{CMAKE_SOURCE_DIR\}/cmake/coverage_helper_export_json.cmake"
      # html report
      COMMAND \$\{LLVMCOV_EXECUTABLE\} show "@\$\{objects_cache\}"
        "-instr-profile=\$\{merged_profiles\}"
        -ignore-filename-regex=.*_interface\\\\..*
        -ignore-filename-regex=.*_thin_wrapper\\\\..*
        -show-line-counts-or-regions
        "-output-dir=\$\{reportdir\}"
        -format=html
        -sources "\$\{CMAKE_SOURCE_DIR\}"
      # terminal summary (uncomment for a quick per-file coverage table on stdout)
      #COMMAND \$\{LLVMCOV_EXECUTABLE\} report "@\$\{objects_cache\}"
      #  "-instr-profile=\$\{merged_profiles\}"
      #  -ignore-filename-regex=.*_interface\\\\..*
      #  -ignore-filename-regex=.*_thin_wrapper\\\\..*
      #  -sources "\$\{CMAKE_SOURCE_DIR\}"
      DEPENDS llvm-cov-merge
      BYPRODUCTS "\$\{reportdir\}/coverage.json"
      COMMENT "Generating code coverage reports"
      WORKING_DIRECTORY "\$\{CMAKE_BINARY_DIR\}"
      VERBATIM
    )

  endif()

else()
  add_custom_target(coverage COMMAND \$\{CMAKE_COMMAND\} -E true COMMENT "Code coverage measurement disabled - nothing to do")
endif()

# add compiler flags to targets for code coverage
function(measure_coverage target)
  if(\$\{COVERAGE_AVAILABLE\})

    if("\$\{CMAKE_C_COMPILER_ID\}" MATCHES "GNU" OR "\$\{CMAKE_CXX_COMPILER_ID\}" MATCHES "GNU")

      target_compile_options(\$\{target\} PRIVATE \$<\$<CONFIG:Debug>:--coverage -fno-inline -fprofile-abs-path>)

      target_link_options(\$\{target\} PUBLIC \$<\$<CONFIG:Debug>:--coverage>)

      # wipe stale .gcda files before re-building object files
      add_custom_command(
        TARGET \$\{target\}
        PRE_BUILD
        COMMAND \$\{CMAKE_COMMAND\}
          -DMODE=wipe-gcda
          "-DSEARCH_DIR=\$\{CMAKE_CURRENT_BINARY_DIR\}"
          -P "\$\{CMAKE_SOURCE_DIR\}/cmake/coverage_helper_wipe_gcda.cmake"
        COMMENT "wiping stale coverage data files"
      )

      get_target_property(_dir \$\{target\} BINARY_DIR)
      set_property(GLOBAL APPEND PROPERTY ${1:`(ide-common-get-project-machine-name)`}_COVERAGE_SEARCH_DIRS "\$\{_dir\}")

    elseif("\$\{CMAKE_C_COMPILER_ID\}" MATCHES "Clang" OR "\$\{CMAKE_CXX_COMPILER_ID\}" MATCHES "Clang")

      target_compile_options(\$\{target\} PRIVATE \$<\$<CONFIG:Debug>:-fprofile-instr-generate -fcoverage-mapping -fno-inline>)

      target_link_options(\$\{target\} PUBLIC \$<\$<CONFIG:Debug>:-fprofile-instr-generate -fcoverage-mapping>)

      get_target_property(_type \$\{target\} TYPE)
      if(_type STREQUAL "SHARED_LIBRARY")
        set_property(GLOBAL APPEND PROPERTY ${1:`(ide-common-get-project-machine-name)`}_COVERAGE_OBJECTS "-object=\$<TARGET_FILE:\$\{target\}>")
      endif()

    endif() # CMAKE_COMPILER_ID

  endif() # COVERAGE_AVAILABLE
endfunction() # measure coverage


# add tests to execute for collecting code coverage metrics
function(report_coverage test)
  if(\$\{COVERAGE_AVAILABLE\})

    if("\$\{CMAKE_C_COMPILER_ID\}" MATCHES "GNU" OR "\$\{CMAKE_CXX_COMPILER_ID\}" MATCHES "GNU")

      add_custom_target(
        "coverage_\$\{test\}"
        COMMAND "\$<TARGET_FILE:\$\{test\}>"
        WORKING_DIRECTORY "\$\{CMAKE_BINARY_DIR\}"
        DEPENDS \$\{test\}
      )
      add_dependencies(coverage "coverage_\$\{test\}")

    elseif("\$\{CMAKE_C_COMPILER_ID\}" MATCHES "Clang" OR "\$\{CMAKE_CXX_COMPILER_ID\}" MATCHES "Clang")

      set(datadir "\$\{PROJECT_BINARY_DIR\}/\$\{CMAKE_COVERAGE_OUTPUT_DIR\}/profiles")
      set(profile "\$\{datadir\}/\$\{test\}.profraw")

      add_custom_target(
        "coverage_\$\{test\}"
        COMMAND \$\{CMAKE_COMMAND\} -E env LLVM_PROFILE_FILE="\$\{profile\}" "\$<TARGET_FILE:\$\{test\}>"
        BYPRODUCTS "\$\{profile\}"
        WORKING_DIRECTORY "\$\{CMAKE_BINARY_DIR\}"
        DEPENDS \$\{test\}
      )
      add_dependencies(llvm-cov-merge "coverage_\$\{test\}")

      set_property(GLOBAL APPEND PROPERTY ${1:`(ide-common-get-project-machine-name)`}_COVERAGE_OBJECTS "-object=\$<TARGET_FILE:\$\{test\}>")
      set_property(GLOBAL APPEND PROPERTY ${1:`(ide-common-get-project-machine-name)`}_COVERAGE_PROFILES "\$\{datadir\}/\$\{test\}.profraw")

    endif()

  endif()
endfunction()


# write generate-time list files and wire up the gcov coverage target;
# must be called from the root CMakeLists.txt after all add_subdirectory() calls
function(finalize_coverage)
  if(NOT \$\{COVERAGE_AVAILABLE\})
    return()
  endif()

  set(reportdir "\$\{PROJECT_BINARY_DIR\}/\$\{CMAKE_COVERAGE_OUTPUT_DIR\}")
  set(datadir "\$\{reportdir\}/profiles")

  if("\$\{CMAKE_C_COMPILER_ID\}" MATCHES "Clang" OR "\$\{CMAKE_CXX_COMPILER_ID\}" MATCHES "Clang")

    get_property(_objects GLOBAL PROPERTY ${1:`(ide-common-get-project-machine-name)`}_COVERAGE_OBJECTS)
    if(NOT _objects)
      message(WARNING "coverage: no objects registered — did you call report_coverage()?")
      return()
    endif()
    string(JOIN "\\n" _objects_content \$\{_objects\})
    # One file per config — the \$<CONFIG> in the output path matches the \$<CONFIG>
    # in objects_cache/profiles_cache used by the custom targets above.
    file(GENERATE
      OUTPUT "\$\{datadir\}/objects-\$<CONFIG>.txt"
      CONTENT "\$\{_objects_content\}\\n"
    )

    get_property(_profiles GLOBAL PROPERTY ${1:`(ide-common-get-project-machine-name)`}_COVERAGE_PROFILES)
    if(NOT _profiles)
      message(WARNING "coverage: no profiles registered — did you call report_coverage()?")
      return()
    endif()
    string(JOIN "\\n" _profiles_content \$\{_profiles\})
    file(GENERATE
      OUTPUT "\$\{reportdir\}/profiles-\$<CONFIG>.txt"
      CONTENT "\$\{_profiles_content\}\\n"
    )

  elseif("\$\{CMAKE_C_COMPILER_ID\}" MATCHES "GNU" OR "\$\{CMAKE_CXX_COMPILER_ID\}" MATCHES "GNU")

    get_property(_search_dirs GLOBAL PROPERTY ${1:`(ide-common-get-project-machine-name)`}_COVERAGE_SEARCH_DIRS)
    if(NOT _search_dirs)
      message(WARNING "coverage: no objects registered — did you call report_coverage()?")
      return()
    endif()

    set(_gcovr_args
      -r "\$\{CMAKE_SOURCE_DIR\}"
      --exclude ".*_thin_wrapper\\\\..*"
      --exclude ".*_interface\\\\..*"
      --exclude-unreachable-branches
      --exclude-throw-branches
    )
    foreach(_dir IN LISTS _search_dirs)
      list(APPEND _gcovr_args --search-path "\$\{_dir\}")
    endforeach()
    list(APPEND _gcovr_args
      --html-details "\$\{reportdir\}/index.html"
      --sonarqube "\$\{reportdir\}/sonarqube.xml"
      # terminal summary (uncomment for a quick per-file coverage table on stdout)
      #--txt
    )

    # The coverage target was created as a dependency aggregator; add the
    # actual gcovr invocation now that all search paths are known.
    add_custom_target(
      _coverage_gcovr
      COMMAND "\$\{GCOVR_EXECUTABLE\}" \$\{_gcovr_args\}
      BYPRODUCTS "\$\{reportdir\}/index.html" "\$\{reportdir\}/sonarqube.xml"
      COMMENT "Running gcovr"
      WORKING_DIRECTORY "\$\{CMAKE_BINARY_DIR\}"
      VERBATIM
    )
    add_dependencies(coverage _coverage_gcovr)

  endif()
endfunction()